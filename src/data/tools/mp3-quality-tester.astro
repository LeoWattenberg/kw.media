---
import ToolPageShell from '../../components/ToolPageShell.astro';
import Mp3QualityTester from '../../components/tools/Mp3QualityTester.astro';
import { defineToolModule } from '../../lib/tool-page-module';

export const toolModule = defineToolModule('mp3-quality-tester', {
	id: 'mp3-quality-tester',
	translations: {
		de: {
			id: 'mp3-quality-tester-de',
			path: '/de/tools/mp3-quality-tester/',
			title: 'MP3-Qualitätstester',
			description: 'Ein clientseitiger Blindtest für MP3-Qualität gegen deine Originaldatei.',
		},
		en: {
			id: 'mp3-quality-tester-en',
			path: '/en/tools/mp3-quality-tester/',
			title: 'MP3 Quality Tester',
			description: 'A client-side blind test for MP3 quality against your original file.',
		},
	},
});

const { tool, alternatePaths } = Astro.props;
---

<ToolPageShell tool={tool} alternatePaths={alternatePaths}>
	<Mp3QualityTester locale={tool.locale} />
</ToolPageShell>
