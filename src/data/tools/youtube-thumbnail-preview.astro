---
import ToolPageShell from '../../components/ToolPageShell.astro';
import YouTubeThumbnailPreview from '../../components/tools/YouTubeThumbnailPreview.astro';
import { defineToolModule } from '../../lib/tool-page-module';

export const toolModule = defineToolModule('youtube-thumbnail-preview', {
	id: 'youtube-thumbnail-preview',
	translations: {
		de: {
			id: 'youtube-thumbnail-preview-de',
			path: '/de/tools/youtube-thumbnail-preview/',
			title: 'YouTube-Thumbnail-Vorschau',
			description: 'Prüfe Thumbnail und Titel in YouTube-Web- und App-Größen direkt im Browser.',
		},
		en: {
			id: 'youtube-thumbnail-preview-en',
			path: '/tools/youtube-thumbnail-preview/',
			title: 'YouTube Thumbnail Preview',
			description: 'Preview your thumbnail and title in YouTube web and app sizes directly in the browser.',
		},
	},
});

const { tool, alternatePaths } = Astro.props;
---

<ToolPageShell tool={tool} alternatePaths={alternatePaths}>
	<YouTubeThumbnailPreview locale={tool.locale} />
</ToolPageShell>
