---
import type { CredentialsBlock } from '../../data/pages';

interface Props {
	block: CredentialsBlock;
}

const { block } = Astro.props;
---

<section class="credentials" aria-label="Credentials">
	<div class="container credentials-inner">
		{block.items.map((item) => <span>{item}</span>)}
	</div>
</section>

<style>
	.credentials {
		background: var(--color-deep);
		color: var(--color-deep-contrast);
	}

	.credentials-inner {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1px;
	}

	span {
		display: grid;
		min-height: 92px;
		place-items: center;
		padding: 18px;
		background: var(--color-deep-subtle);
		font-weight: 800;
		text-align: center;
	}
</style>
