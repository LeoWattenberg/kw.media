---
import type { Locale } from '../../i18n';
import { gateYouTubeEmbedsInHtml } from '../../lib/youtube-consent';

interface Props {
	html: string;
	locale: Locale;
}

const { html, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
let contentHtml = gateYouTubeEmbedsInHtml(html, locale);

if (base) {
	const baseSegment = base.replace(/^\//, '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
	contentHtml = contentHtml
		.replaceAll('/assets/wp-content/uploads/', `${base}/assets/wp-content/uploads/`)
		.replace(new RegExp(`(href|src)="/(?!${baseSegment}/)`, 'g'), `$1="${base}/`);
}
---

<section class="section raw-content">
	<div class="container content-html" set:html={contentHtml} />
</section>

<style is:global>
	.content-html {
		max-width: 860px;
	}

	.content-html h1,
	.content-html h2,
	.content-html h3,
	.content-html h4 {
		margin: 1.15em 0 0.35em;
		line-height: 1.08;
		letter-spacing: 0;
	}

	.content-html h1 {
		font-size: clamp(2.4rem, 6vw, 4.6rem);
	}

	.content-html h2 {
		font-size: clamp(1.9rem, 4vw, 3rem);
	}

	.content-html > :first-child {
		margin-top: 0;
	}

	.content-html p,
	.content-html li {
		color: var(--color-muted);
		font-size: 1.05rem;
	}

	.content-html p {
		margin: 0 0 0.85em;
	}

	.content-html :is(h1, h2, h3, h4) + p {
		margin-top: 0;
	}

	.content-html a {
		color: var(--color-accent-dark);
		font-weight: 750;
	}

	.content-html img {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.content-html figure {
		margin: 32px 0;
	}

	.content-html iframe {
		width: 100%;
		max-width: 100%;
		aspect-ratio: 16 / 9;
		height: auto;
		border: 0;
	}

	.raw-content {
		background: #fff;
	}
</style>
