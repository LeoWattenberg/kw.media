---
import type { CtaBlock } from '../../data/pages';

interface Props {
	block: CtaBlock;
}

const { block } = Astro.props;
---

<section class="cta">
	<div class="container cta-inner">
		<div>
			<h2>{block.title}</h2>
			<p>{block.text}</p>
			{
				block.items && (
					<ul>
						{block.items.map((item) => <li>{item}</li>)}
					</ul>
				)
			}
		</div>
		<a href={`mailto:${block.email}`}>{block.email}</a>
	</div>
</section>

<style>
	.cta {
		padding-block: clamp(48px, 8vw, 88px);
		color: #fff;
		background: var(--color-deep);
	}

	.cta-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 28px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	p {
		max-width: 52rem;
		margin: 18px 0 0;
		color: rgba(255, 255, 255, 0.78);
	}

	ul {
		display: grid;
		gap: 8px;
		margin: 20px 0 0;
		padding: 0;
		list-style: none;
		color: rgba(255, 255, 255, 0.82);
	}

	li::before {
		content: '✓';
		margin-right: 8px;
		color: #fff;
	}

	a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 18px;
		color: var(--color-deep);
		background: #fff;
		border-radius: 6px;
		font-weight: 900;
		text-decoration: none;
		white-space: nowrap;
	}

	@media (max-width: 760px) {
		.cta-inner {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
