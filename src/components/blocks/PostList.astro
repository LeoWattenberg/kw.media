---
import type { PostListBlock } from '../../data/pages';
import type { Locale } from '../../i18n';
import type { Category } from '../../lib/source-content';
import { getAllPosts } from '../../lib/source-content';
import { withBase } from '../../lib/url';

interface Props {
	block: PostListBlock;
	locale: Locale;
}

const { block, locale } = Astro.props;
const includedCategories = block.categories ? new Set<Category>(block.categories) : undefined;
const posts = getAllPosts()
	.filter((post) => post.locale === locale)
	.filter((post) => (block.authorName ? post.authorName === block.authorName : true))
	.filter((post) => (includedCategories ? includedCategories.has(post.category) : true))
	.slice(0, block.limit);

const categoryLabels: Record<Locale, Record<Category, string>> = {
	de: {
		blog: 'Blog',
		'short-tutorial': 'Kurztutorials',
		'video-tutorial': 'Video-Tutorials',
		'news-video': 'News-Videos',
		audacity: 'Audacity',
	},
	en: {
		blog: 'Blog',
		'short-tutorial': 'Short tutorials',
		'video-tutorial': 'Video tutorials',
		'news-video': 'News videos',
		audacity: 'Audacity',
	},
};

const allLabel = locale === 'de' ? 'Alle' : 'All';
const emptyLabel = locale === 'de' ? 'Keine Beiträge in dieser Kategorie.' : 'No posts in this category.';
const searchLabel = locale === 'de' ? 'Beiträge durchsuchen' : 'Search posts';
const searchPlaceholder = locale === 'de' ? 'Nach YouTube, OBS, Shorts ... suchen' : 'Search YouTube, OBS, Shorts ...';
const allCategories: Category[] = ['blog', 'short-tutorial', 'video-tutorial', 'news-video', 'audacity'];
const categoryOrder = block.categories ?? allCategories;
const postCounts = Object.fromEntries(categoryOrder.map((category) => [category, posts.filter((post) => post.category === category).length])) as Record<
	Category,
	number
>;
const showCategoryControls = !block.limit && posts.length > 0;
const showSearchControls = !block.limit && posts.length > 0;
const searchId = `post-search-${locale}-${block.title.toLowerCase().replace(/[^a-z0-9]+/g, '-') || 'posts'}`;
---

<section class="section posts" data-post-list>
	<div class="container">
		<div class="section-head">
			<h2>{block.title}</h2>
			{block.moreHref && <a href={withBase(block.moreHref)}>{block.moreLabel ?? 'More'}</a>}
		</div>
		{
			showSearchControls && (
				<div class="post-search">
					<label for={searchId}>{searchLabel}</label>
					<input id={searchId} type="search" placeholder={searchPlaceholder} autocomplete="off" data-post-search />
				</div>
			)
		}
		{
			showCategoryControls && (
				<div class="category-controls" aria-label={locale === 'de' ? 'Beitragskategorien' : 'Post categories'}>
					<button type="button" class="active" data-post-filter="all" aria-pressed="true">
						{allLabel}
						<span>{posts.length}</span>
					</button>
					{categoryOrder.map((category) => (
						<button type="button" data-post-filter={category} aria-pressed="false">
							{categoryLabels[locale][category]}
							<span>{postCounts[category]}</span>
						</button>
					))}
				</div>
			)
		}
		<div class="post-grid">
			{
				posts.map((post) => (
					<article data-post-category={post.category}>
						{post.image && <img src={withBase(post.image)} alt="" loading="lazy" />}
						<div>
							<time datetime={post.date}>{new Date(post.date).toLocaleDateString(post.locale === 'de' ? 'de-DE' : 'en-US')}</time>
							<h3><a href={withBase(post.path)}>{post.title}</a></h3>
							<p>{post.excerpt}</p>
						</div>
					</article>
				))
			}
		</div>
		{showCategoryControls && <p class="empty-state" data-empty-message hidden>{emptyLabel}</p>}
	</div>
</section>

<script>
	document.querySelectorAll<HTMLElement>('[data-post-list]').forEach((list) => {
		const buttons = Array.from(list.querySelectorAll<HTMLButtonElement>('[data-post-filter]'));
		const posts = Array.from(list.querySelectorAll<HTMLElement>('[data-post-category]'));
		const searchInput = list.querySelector<HTMLInputElement>('[data-post-search]');
		const emptyMessage = list.querySelector<HTMLElement>('[data-empty-message]');

		function normalizeSearch(value: string) {
			return value
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.trim();
		}

		function activeCategory() {
			return buttons.find((button) => button.classList.contains('active'))?.dataset.postFilter ?? 'all';
		}

		function applyFilter(filter: string | undefined, updateUrl = false) {
			const activeFilter = buttons.some((button) => button.dataset.postFilter === filter) ? filter : 'all';
			const query = normalizeSearch(searchInput?.value ?? '');
			let visibleCount = 0;

			buttons.forEach((candidate) => {
				const isActive = candidate.dataset.postFilter === activeFilter;
				candidate.classList.toggle('active', isActive);
				candidate.setAttribute('aria-pressed', String(isActive));
			});

			posts.forEach((post) => {
				const matchesCategory = activeFilter === 'all' || post.dataset.postCategory === activeFilter;
				const matchesSearch = !query || normalizeSearch(post.textContent ?? '').includes(query);
				const shouldShow = matchesCategory && matchesSearch;
				post.hidden = !shouldShow;
				if (shouldShow) {
					visibleCount += 1;
				}
			});

			if (emptyMessage) {
				emptyMessage.hidden = visibleCount > 0;
			}

			if (updateUrl) {
				const url = new URL(window.location.href);
				if (activeFilter && activeFilter !== 'all') {
					url.searchParams.set('category', activeFilter);
				} else {
					url.searchParams.delete('category');
				}
				if (searchInput?.value.trim()) {
					url.searchParams.set('q', searchInput.value.trim());
				} else {
					url.searchParams.delete('q');
				}
				window.history.replaceState({}, '', url);
			}
		}

		const searchParams = new URLSearchParams(window.location.search);
		const requestedFilter = searchParams.get('category') ?? searchParams.get('type') ?? window.location.hash.replace(/^#/, '');
		const requestedSearch = searchParams.get('q') ?? '';
		if (searchInput && requestedSearch) {
			searchInput.value = requestedSearch;
		}
		applyFilter(requestedFilter);

		buttons.forEach((button) => {
			button.addEventListener('click', () => {
				applyFilter(button.dataset.postFilter, true);
			});
		});

		searchInput?.addEventListener('input', () => {
			applyFilter(activeCategory(), true);
		});
	});
</script>

<style>
	.posts {
		background: var(--color-surface-raised);
	}

	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 30px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	.section-head > a {
		color: var(--color-accent-dark);
		font-weight: 850;
		text-decoration: none;
	}

	.category-controls {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: -10px 0 28px;
	}

	.post-search {
		display: grid;
		gap: 8px;
		max-width: 560px;
		margin: -12px 0 24px;
	}

	.post-search label {
		color: var(--color-muted);
		font-size: 0.86rem;
		font-weight: 850;
		text-transform: uppercase;
	}

	.post-search input {
		width: 100%;
		border: 1px solid var(--color-line);
		border-radius: 8px;
		background: var(--color-surface-raised);
		color: var(--color-text);
		font: inherit;
		font-size: 1rem;
		padding: 12px 14px;
	}

	.post-search input:focus {
		border-color: var(--color-accent-dark);
		outline: 2px solid var(--color-accent-focus-subtle);
		outline-offset: 2px;
	}

	.category-controls button {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		border: 1px solid var(--color-line);
		border-radius: 999px;
		background: var(--color-surface-raised);
		color: var(--color-text);
		cursor: pointer;
		font: inherit;
		font-weight: 800;
		padding: 9px 14px;
	}

	.category-controls button.active {
		border-color: var(--color-accent-dark);
		background: var(--color-accent-dark);
		color: var(--color-deep-contrast);
	}

	.category-controls span {
		color: var(--color-muted);
		font-size: 0.82rem;
	}

	.category-controls button.active span {
		color: currentColor;
		opacity: 0.78;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 16px;
	}

	article {
		overflow: hidden;
		background: var(--color-surface-alt);
		border: 1px solid var(--color-line);
		border-radius: 8px;
	}

	article[hidden],
	.empty-state[hidden] {
		display: none;
	}

	img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		background: var(--color-line);
	}

	article > div {
		padding: 20px;
	}

	time {
		color: var(--color-muted);
		font-size: 0.88rem;
		font-weight: 750;
	}

	h3 {
		margin: 8px 0 10px;
		font-size: 1.2rem;
		line-height: 1.2;
	}

	h3 a {
		text-decoration: none;
	}

	p {
		margin: 0;
		color: var(--color-muted);
	}

	.empty-state {
		border: 1px dashed var(--color-line);
		border-radius: 8px;
		padding: 24px;
		text-align: center;
	}
</style>
