---
import type { PagePlan } from '../../data/pages';
import { blockLabels } from '../../lib/blocks';
import { useTranslations } from '../../i18n';

interface Props {
	page: PagePlan;
}

const { page } = Astro.props;
const t = useTranslations(page.locale);
---

<article class="page-plan">
	<div class="page-plan-header">
		<div>
			<p class="path">{page.path}</p>
			<h2>{page.title}</h2>
		</div>
		<span>{page.kind}</span>
	</div>
	<p class="source">
		{t('review.source')}: {page.source}{page.sourceId ? `#${page.sourceId}` : ''}
	</p>
	<h3>{t('review.blocks')}</h3>
	<ol>
		{
			page.blocks.map((block) => (
				<li>
					<strong>{blockLabels[block.kind]}</strong>
					<span>{block.name}</span>
				</li>
			))
		}
	</ol>
</article>

<style>
	.page-plan {
		display: grid;
		gap: 18px;
		padding: 24px;
		background: var(--color-surface);
		border: 1px solid var(--color-line);
		border-radius: 8px;
	}

	.page-plan-header {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 18px;
	}

	.path,
	.source {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.92rem;
	}

	h2,
	h3 {
		margin: 0;
		letter-spacing: 0;
	}

	h2 {
		font-size: clamp(1.5rem, 3vw, 2.2rem);
	}

	h3 {
		font-size: 1rem;
	}

	.page-plan-header span {
		padding: 4px 8px;
		color: var(--color-accent-dark);
		background: #fff0ef;
		border-radius: 6px;
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	ol {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		display: grid;
		gap: 4px;
		min-height: 74px;
		padding: 14px;
		background: var(--color-surface-alt);
		border-radius: 6px;
	}

	li strong {
		font-size: 0.9rem;
	}

	li span {
		color: var(--color-muted);
		font-size: 0.9rem;
	}
</style>
