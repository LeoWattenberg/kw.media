---
import type { ServicesBlock } from '../../data/pages';
import { withBase } from '../../lib/url';

interface Props {
	block: ServicesBlock;
}

const { block } = Astro.props;
---

<section class="section services">
	<div class="container">
		<div class="section-head">
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h2>{block.title}</h2>
			{block.intro && <p>{block.intro}</p>}
		</div>
		<div class="grid">
			{
				block.items.map((item) => (
					<article>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
						{item.href && <a href={withBase(item.href)}>{block.linkLabel ?? 'Learn more'}</a>}
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services {
		background: #fff;
	}

	.section-head {
		max-width: 760px;
		margin-bottom: 34px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4.2rem);
		line-height: 1;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.section-head > p:not(.eyebrow) {
		margin: 16px 0 0;
		color: var(--color-muted);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	article {
		min-height: 210px;
		padding: 24px;
		background: var(--color-surface-alt);
		border: 1px solid var(--color-line);
		border-radius: 8px;
	}

	h3 {
		margin: 0 0 12px;
		font-size: 1.3rem;
		letter-spacing: 0;
	}

	article p {
		margin: 0;
		color: var(--color-muted);
	}

	a {
		display: inline-block;
		margin-top: 18px;
		color: var(--color-accent-dark);
		font-weight: 800;
		text-decoration: none;
	}

	@media (max-width: 880px) {
		.grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
