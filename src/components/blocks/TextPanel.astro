---
import type { TextBlock } from '../../data/pages';
import { localizeMediaUrl } from '../../lib/media';
import { withBase } from '../../lib/url';

interface Props {
	block: TextBlock;
}

const { block } = Astro.props;
const image = block.image ? localizeMediaUrl(block.image) : undefined;
---

<section class="section text-panel">
	<div class:list={['container', 'text-inner', block.reverse && 'reverse', !image && 'no-image']}>
		<div>
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h2>{block.title}</h2>
			{block.body.map((paragraph) => <p>{paragraph}</p>)}
			{
				block.checks && (
					<ul>
						{block.checks.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				)
			}
		</div>
		{
			image && (
				<img src={withBase(image)} alt={block.imageAlt ?? ''} loading="lazy" />
			)
		}
	</div>
</section>

<style>
	.text-panel {
		background: var(--color-surface-alt);
	}

	.text-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.68fr);
		gap: clamp(32px, 7vw, 80px);
		align-items: center;
	}

	.text-inner.reverse {
		grid-template-columns: minmax(280px, 0.68fr) minmax(0, 1fr);
	}

	.text-inner.no-image {
		display: block;
		max-width: 920px;
	}

	.text-inner.reverse img {
		order: -1;
	}

	h2 {
		margin: 0;
		font-size: clamp(2.1rem, 5vw, 4.4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	p:not(.eyebrow) {
		max-width: 48rem;
		margin: 18px 0 0;
		color: var(--color-muted);
		font-size: 1.06rem;
	}

	ul {
		display: grid;
		gap: 10px;
		margin: 24px 0 0;
		padding: 0;
		list-style: none;
	}

	li {
		color: var(--color-ink);
		font-weight: 750;
	}

	li::before {
		content: '✓';
		margin-right: 10px;
		color: var(--color-accent);
	}

	img {
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: 8px;
	}

	@media (max-width: 820px) {
		.text-inner,
		.text-inner.reverse {
			grid-template-columns: 1fr;
		}

		.text-inner.reverse img {
			order: 0;
		}
	}
</style>
