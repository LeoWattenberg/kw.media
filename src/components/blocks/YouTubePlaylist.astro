---
import type { YouTubePlaylistBlock } from '../../data/pages';

interface Props {
	block: YouTubePlaylistBlock;
}

const { block } = Astro.props;
const playlistUrl = `https://www.youtube.com/embed/videoseries?list=${encodeURIComponent(block.playlistId)}`;
---

<section class="section news">
	<div class="container news-inner">
		<div class="section-head">
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h2>{block.title}</h2>
		</div>
		<div class="playlist-frame">
			<iframe
				src={playlistUrl}
				title={block.title}
				loading="lazy"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				referrerpolicy="strict-origin-when-cross-origin"
				allowfullscreen
			></iframe>
		</div>
	</div>
</section>

<style>
	.news {
		background: var(--color-surface-alt);
	}

	.news-inner {
		display: grid;
		gap: 28px;
	}

	.section-head {
		max-width: 760px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	.playlist-frame {
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: var(--color-deep);
		border: 1px solid var(--color-line);
		border-radius: 8px;
		box-shadow: 0 18px 60px rgba(36, 25, 19, 0.12);
	}

	iframe {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>
