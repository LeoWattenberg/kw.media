---
import type { YouTubePlaylistBlock } from '../../data/pages';
import YouTubeConsentEmbed from '../YouTubeConsentEmbed.astro';

interface Props {
	block: YouTubePlaylistBlock;
	locale: 'de' | 'en';
}

const { block, locale } = Astro.props;
const playlistUrl = `https://www.youtube.com/embed/videoseries?list=${encodeURIComponent(block.playlistId)}`;
---

<section class="section news">
	<div class="container news-inner">
		<div class="section-head">
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h2>{block.title}</h2>
		</div>
		<YouTubeConsentEmbed
			class="playlist-frame"
			locale={locale}
			src={playlistUrl}
			title={block.title}
			referrerpolicy="strict-origin-when-cross-origin"
		/>
	</div>
</section>

<style>
	.news {
		background: var(--color-surface-alt);
	}

	.news-inner {
		display: grid;
		gap: 28px;
	}

	.section-head {
		max-width: 760px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1;
		letter-spacing: 0;
	}

	.playlist-frame {
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: var(--color-deep);
		border: 1px solid var(--color-line);
		border-radius: 8px;
		box-shadow: var(--shadow-soft);
	}

	.playlist-frame :global(iframe) {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.playlist-frame :global(.youtube-consent-placeholder) {
		min-height: 100%;
	}
</style>
