---
import type { SourcePost } from '../lib/source-content';
import { withBase } from '../lib/url';
import { getAuthorPath } from '../data/authors';
import ContentHtml from './blocks/ContentHtml.astro';
import YouTubeConsentEmbed from './YouTubeConsentEmbed.astro';

interface Props {
	post: SourcePost;
}

const { post } = Astro.props;
const authorPath = getAuthorPath(post.authorName, post.locale);
const isShortVideo = post.video?.watchUrl.includes('/shorts/');
const videoClass = `container hero-video ${isShortVideo ? 'hero-video--short' : 'hero-video--wide'}`;
const formattedDate = new Date(post.date).toLocaleDateString(post.locale === 'de' ? 'de-DE' : 'en-US', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
---

<article>
	<header class="article-hero">
		<div class="container article-head">
			<div class="article-meta">
				<time class="eyebrow" datetime={post.date}>{formattedDate}</time>
				{
					authorPath ? (
						<a class="eyebrow" href={withBase(authorPath)}>{post.authorName}</a>
					) : (
						<span class="eyebrow">{post.authorName}</span>
					)
				}
			</div>
			<h1>{post.title}</h1>
			{post.excerpt && <p>{post.excerpt}</p>}
		</div>
		{
			post.video ? (
				<YouTubeConsentEmbed class={videoClass} locale={post.locale} title={post.title} src={post.video.embedUrl} loading="eager" />
			) : (
				post.image && <img src={withBase(post.image)} alt="" loading="eager" />
			)
		}
	</header>
	<ContentHtml html={post.contentHtml} locale={post.locale} />
</article>

<style>
	.article-hero {
		padding-block: clamp(48px, 8vw, 92px);
		background: var(--color-surface-alt);
		border-bottom: 1px solid var(--color-line);
	}

	.article-head {
		max-width: 920px;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 14px;
		align-items: center;
		margin-bottom: 8px;
	}

	.article-meta a {
		color: var(--color-accent-dark);
		text-decoration: none;
	}

	.article-meta a:hover {
		text-decoration: underline;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.6rem, 7vw, 5.6rem);
		line-height: 0.98;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.article-head > p:not(.eyebrow) {
		max-width: 720px;
		margin: 22px 0 0;
		color: var(--color-muted);
		font-size: 1.12rem;
	}

	.article-hero img {
		display: block;
		width: min(1120px, calc(100% - 32px));
		max-height: 560px;
		margin: 36px auto 0;
		object-fit: cover;
		border-radius: 8px;
	}

	.hero-video {
		margin-top: 36px;
	}

	.hero-video--short {
		aspect-ratio: 9 / 16;
		max-width: 420px;
	}

	.hero-video :global(iframe),
	.hero-video :global(.youtube-consent-placeholder) {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		height: auto;
		border: 0;
		border-radius: 8px;
		background: #000;
	}

	.hero-video--short :global(iframe),
	.hero-video--short :global(.youtube-consent-placeholder) {
		aspect-ratio: 9 / 16;
	}
</style>
