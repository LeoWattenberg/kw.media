---
import { getPostNavigation, getRelatedPosts, type Category, type SourcePost } from '../lib/source-content';
import { withBase } from '../lib/url';
import { getAuthorPath } from '../data/authors';
import { routeFor } from '../i18n';
import ContentHtml from './blocks/ContentHtml.astro';
import YouTubeConsentEmbed from './YouTubeConsentEmbed.astro';

interface Props {
	post: SourcePost;
}

const { post } = Astro.props;
const authorPath = getAuthorPath(post.authorName, post.locale);
const isShortVideo = post.video?.watchUrl.includes('/shorts/');
const videoClass = `container hero-video ${isShortVideo ? 'hero-video--short' : 'hero-video--wide'}`;
const postNavigation = getPostNavigation(post);
const relatedPosts = getRelatedPosts(post);
const postOverviewPath = routeFor('tips', post.locale);
const formattedDate = new Date(post.date).toLocaleDateString(post.locale === 'de' ? 'de-DE' : 'en-US', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const categoryLabels: Record<typeof post.locale, Record<Category, string>> = {
	de: {
		blog: 'Blog',
		'short-tutorial': 'Kurztutorials',
		'video-tutorial': 'Video-Tutorials',
		'news-video': 'News-Videos',
	},
	en: {
		blog: 'Blog',
		'short-tutorial': 'Short tutorials',
		'video-tutorial': 'Video tutorials',
		'news-video': 'News videos',
	},
};

const navigationLabels = {
	de: {
		heading: 'Weitere Beiträge',
		related: 'Passende Beiträge',
		chronological: 'Chronologisch',
		category: 'In derselben Kategorie',
		previous: 'Älterer Beitrag',
		next: 'Neuerer Beitrag',
	},
	en: {
		heading: 'More posts',
		related: 'Related posts',
		chronological: 'Chronological',
		category: 'In the same category',
		previous: 'Older post',
		next: 'Newer post',
	},
}[post.locale];

const navigationSections = [
	{
		title: navigationLabels.chronological,
		previous: postNavigation.chronological.previous,
		next: postNavigation.chronological.next,
	},
	{
		title: navigationLabels.category,
		categoryLabel: categoryLabels[post.locale][post.category],
		categoryHref: `${postOverviewPath}?category=${post.category}`,
		previous: postNavigation.category.previous,
		next: postNavigation.category.next,
	},
];
const hasPostNavigation = navigationSections.some((section) => section.previous || section.next);
const hasRelatedPosts = relatedPosts.length > 0;

function formatPostDate(navigationPost: SourcePost): string {
	return new Date(navigationPost.date).toLocaleDateString(navigationPost.locale === 'de' ? 'de-DE' : 'en-US', {
		day: 'numeric',
		month: 'long',
		year: 'numeric',
	});
}
---

<article>
	<header class="article-hero">
		<div class="container article-head">
			<div class="article-meta">
				<time class="eyebrow" datetime={post.date}>{formattedDate}</time>
				{
					authorPath ? (
						<a class="eyebrow" href={withBase(authorPath)}>{post.authorName}</a>
					) : (
						<span class="eyebrow">{post.authorName}</span>
					)
				}
			</div>
			<h1>{post.title}</h1>
			{post.excerpt && <p>{post.excerpt}</p>}
		</div>
		{
			post.video ? (
				<YouTubeConsentEmbed class={videoClass} locale={post.locale} title={post.title} src={post.video.embedUrl} loading="eager" />
			) : (
				post.image && <img src={withBase(post.image)} alt="" loading="eager" />
			)
		}
	</header>
	<ContentHtml html={post.contentHtml} locale={post.locale} />
	{
		hasRelatedPosts && (
			<aside class="related-posts" aria-labelledby="related-posts-heading">
				<div class="container related-posts-inner">
					<h2 id="related-posts-heading">{navigationLabels.related}</h2>
					<div class="related-posts-grid">
						{relatedPosts.map((relatedPost) => (
							<a class="related-post-card" href={withBase(relatedPost.path)}>
								<strong>{relatedPost.title}</strong>
								{relatedPost.excerpt && <span>{relatedPost.excerpt}</span>}
							</a>
						))}
					</div>
				</div>
			</aside>
		)
	}
	{
		hasPostNavigation && (
			<nav class="post-navigation" aria-labelledby="post-navigation-heading">
				<div class="container post-navigation-inner">
					<h2 id="post-navigation-heading">{navigationLabels.heading}</h2>
					<div class="post-navigation-grid">
						{navigationSections.map((section) => (
							<section class="post-navigation-section">
								<h3>
									{section.categoryLabel && section.categoryHref && (
										<>
											{section.title}: {' '}
											<a href={withBase(section.categoryHref)}>{section.categoryLabel}</a>
										</>
									)}
									{!section.categoryLabel && section.title}
								</h3>
								<div class="post-navigation-links">
									{section.previous && (
										<a class="post-navigation-card" href={withBase(section.previous.path)}>
											<span>{navigationLabels.previous}</span>
											<strong>{section.previous.title}</strong>
											<time datetime={section.previous.date}>{formatPostDate(section.previous)}</time>
										</a>
									)}
									{section.next && (
										<a class="post-navigation-card post-navigation-card--next" href={withBase(section.next.path)}>
											<span>{navigationLabels.next}</span>
											<strong>{section.next.title}</strong>
											<time datetime={section.next.date}>{formatPostDate(section.next)}</time>
										</a>
									)}
								</div>
							</section>
						))}
					</div>
				</div>
			</nav>
		)
	}
</article>

<style>
	.article-hero {
		padding-block: clamp(48px, 8vw, 92px);
		background: var(--color-surface-alt);
		border-bottom: 1px solid var(--color-line);
	}

	.article-head {
		max-width: 920px;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 14px;
		align-items: center;
		margin-bottom: 8px;
	}

	.article-meta a {
		color: var(--color-accent-dark);
		text-decoration: none;
	}

	.article-meta a:hover {
		text-decoration: underline;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.6rem, 7vw, 5.6rem);
		line-height: 0.98;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.article-head > p:not(.eyebrow) {
		max-width: 720px;
		margin: 22px 0 0;
		color: var(--color-muted);
		font-size: 1.12rem;
	}

	.article-hero img {
		display: block;
		width: min(1120px, calc(100% - 32px));
		max-height: 560px;
		margin: 36px auto 0;
		object-fit: cover;
		border-radius: 8px;
	}

	.hero-video {
		margin-top: 36px;
	}

	.hero-video--short {
		aspect-ratio: 9 / 16;
		max-width: 420px;
	}

	.hero-video :global(iframe),
	.hero-video :global(.youtube-consent-placeholder) {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		height: auto;
		border: 0;
		border-radius: 8px;
		background: #000;
	}

	.hero-video--short :global(iframe),
	.hero-video--short :global(.youtube-consent-placeholder) {
		aspect-ratio: 9 / 16;
	}

	.related-posts {
		padding-block: clamp(38px, 6vw, 64px);
		background: var(--color-surface-alt);
		border-top: 1px solid var(--color-line);
	}

	.related-posts-inner {
		max-width: 920px;
	}

	.related-posts h2 {
		margin: 0 0 20px;
		font-size: clamp(1.7rem, 3vw, 2.6rem);
		line-height: 1.1;
		letter-spacing: 0;
	}

	.related-posts-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.related-post-card {
		display: grid;
		gap: 10px;
		align-content: start;
		min-height: 160px;
		padding: 18px;
		background: #fff;
		border: 1px solid var(--color-line);
		border-radius: 8px;
		color: inherit;
		text-decoration: none;
	}

	.related-post-card:hover {
		border-color: var(--color-accent-dark);
	}

	.related-post-card strong {
		font-size: 1.04rem;
		line-height: 1.22;
	}

	.related-post-card span {
		color: var(--color-muted);
		font-size: 0.92rem;
		line-height: 1.45;
	}

	.post-navigation {
		padding-block: clamp(42px, 7vw, 76px);
		background: #fff;
		border-top: 1px solid var(--color-line);
	}

	.post-navigation-inner {
		max-width: 860px;
	}

	.post-navigation h2 {
		margin: 0 0 24px;
		font-size: clamp(1.9rem, 4vw, 3rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	.post-navigation-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 24px;
	}

	.post-navigation-section {
		min-width: 0;
	}

	.post-navigation-section h3 {
		margin: 0 0 12px;
		color: var(--color-muted);
		font-size: 0.86rem;
		font-weight: 850;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.post-navigation-section h3 a {
		color: var(--color-accent-dark);
		text-decoration: none;
	}

	.post-navigation-section h3 a:hover {
		text-decoration: underline;
	}

	.post-navigation-links {
		display: grid;
		gap: 16px;
	}

	.post-navigation-card {
		display: grid;
		gap: 6px;
		min-height: 132px;
		align-content: start;
		padding: 18px;
		background: var(--color-surface-alt);
		border: 1px solid var(--color-line);
		border-radius: 8px;
		color: inherit;
		text-decoration: none;
	}

	.post-navigation-card:hover {
		border-color: var(--color-accent-dark);
	}

	.post-navigation-card span {
		color: var(--color-accent-dark);
		font-size: 0.78rem;
		font-weight: 850;
		text-transform: uppercase;
	}

	.post-navigation-card strong {
		font-size: 1.08rem;
		line-height: 1.22;
	}

	.post-navigation-card time {
		margin-top: auto;
		color: var(--color-muted);
		font-size: 0.88rem;
		font-weight: 750;
	}

	@media (max-width: 760px) {
		.related-posts-grid {
			grid-template-columns: 1fr;
		}

		.post-navigation-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
