---
import StructureHero from './blocks/StructureHero.astro';
import BlockPlanList from './blocks/BlockPlanList.astro';
import { pagePlans, type PagePlan } from '../data/pages';
import type { Locale } from '../i18n';

interface Props {
	locale: Locale;
	currentPage?: PagePlan;
}

const { locale, currentPage } = Astro.props;
const visiblePlans = currentPage ? [currentPage] : pagePlans;
---

<StructureHero locale={locale} />
<section class="section review-list">
	<div class="container plans">
		{visiblePlans.map((page) => <BlockPlanList page={page} />)}
	</div>
</section>

<style>
	.review-list {
		background: var(--color-surface-alt);
	}

	.plans {
		display: grid;
		gap: 18px;
	}
</style>
