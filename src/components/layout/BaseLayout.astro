---
import CookieConsent from './CookieConsent.astro';
import SiteFooter from './SiteFooter.astro';
import SiteSidebar from './SiteSidebar.astro';
import type { Locale } from '../../i18n';
import { useTranslations } from '../../i18n';
import type { AuthorProfile } from '../../data/authors';
import { getAuthorPath } from '../../data/authors';
import { localizeMediaUrl } from '../../lib/media';
import { withBase } from '../../lib/url';

type SchemaType = 'WebPage' | 'BlogPosting' | 'VideoObject' | 'ProfilePage';
type AlternatePaths = Partial<Record<Locale, string>>;

interface FaqItem {
	question: string;
	answer: string[];
}

interface Props {
	locale: Locale;
	title: string;
	description?: string;
	preloadImage?: string;
	canonicalPath?: string;
	alternatePaths?: AlternatePaths;
	image?: string;
	imageAlt?: string;
	schemaType?: SchemaType;
	publishedTime?: string;
	modifiedTime?: string;
	authorName?: string;
	profileAuthor?: AuthorProfile;
	video?: {
		youtubeId: string;
		embedUrl: string;
		watchUrl: string;
		thumbnailUrl: string;
	};
	faqItems?: FaqItem[];
}

const {
	locale,
	title,
	description = 'Koytek Wattenberg Media',
	preloadImage,
	canonicalPath = Astro.url.pathname,
	alternatePaths,
	image,
	imageAlt,
	schemaType = 'WebPage',
	publishedTime,
	modifiedTime,
	authorName,
	profileAuthor,
	video,
	faqItems = [],
} = Astro.props;
const t = useTranslations(locale);
const siteName = t('siteName');
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname;
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? 'G-YTNCM94GGV';
const themeStorageKey = 'kwm_theme';
const rssHref = withBase(locale === 'de' ? '/de/rss.xml' : '/en/rss.xml');
const rssUrl = Astro.site ? new URL(rssHref, Astro.site).toString() : rssHref;
const rssTitle = locale === 'de' ? 'Koytek Wattenberg Media - YouTube Tipps' : 'Koytek Wattenberg Media - YouTube Tips';
const priorityImage = localizeMediaUrl(preloadImage);
const priorityImageHref = priorityImage ? withBase(priorityImage) : undefined;
const priorityImagePreloadHref = priorityImageHref ? encodeURI(priorityImageHref) : undefined;
const socialImage = localizeMediaUrl(image ?? preloadImage);
const authorPath = authorName ? getAuthorPath(authorName, locale) : undefined;

function absoluteUrl(href: string): string {
	const url = withBase(href);
	return Astro.site ? new URL(url, Astro.site).toString() : url;
}

const canonicalHref = absoluteUrl(canonicalPath);
const socialImageHref = socialImage ? absoluteUrl(socialImage) : undefined;
const authorHref = authorPath ? absoluteUrl(authorPath) : undefined;
const authorId = authorHref ? `${authorHref}#person` : undefined;
const effectiveAlternatePaths = {
	[locale]: canonicalPath,
	...alternatePaths,
};
const alternateLinks = Object.entries(effectiveAlternatePaths)
	.filter((entry): entry is [Locale, string] => Boolean(entry[1]))
	.map(([hreflang, path]) => ({ hreflang, href: absoluteUrl(path) }));
const alternateLinksWithDefault =
	alternateLinks.length > 1 && effectiveAlternatePaths.de
		? [...alternateLinks, { hreflang: 'x-default', href: absoluteUrl(effectiveAlternatePaths.de) }]
		: alternateLinks;
const ogLocaleByLocale = {
	de: 'de_DE',
	en: 'en_US',
} satisfies Record<Locale, string>;
const schemaLanguageByLocale = {
	de: 'de-DE',
	en: 'en-US',
} satisfies Record<Locale, string>;
const ogLocaleAlternates = alternateLinks
	.map((alternate) => alternate.hreflang)
	.filter((hreflang): hreflang is Locale => hreflang !== locale && hreflang in ogLocaleByLocale)
	.map((alternateLocale) => ogLocaleByLocale[alternateLocale]);
const siteUrl = absoluteUrl('/');
const organizationId = `${siteUrl}#organization`;
const websiteId = `${siteUrl}#website`;
const webPageId = `${canonicalHref}#webpage`;
const breadcrumbId = `${canonicalHref}#breadcrumb`;
const articleId = `${canonicalHref}#article`;
const videoId = `${canonicalHref}#video`;
const profilePersonId = `${canonicalHref}#person`;
const homePath = locale === 'en' ? '/en/' : '/';
const isHomePage = canonicalPath === '/' || canonicalPath === '/en/';
const breadcrumbItems = [
	{
		'@type': 'ListItem',
		position: 1,
		name: siteName,
		item: absoluteUrl(homePath),
	},
	...(
		isHomePage
			? []
			: [
					{
						'@type': 'ListItem',
						position: 2,
						name: title,
						item: canonicalHref,
					},
				]
	),
];
const organizationSchema = {
	'@type': 'Organization',
	'@id': organizationId,
	name: 'Koytek Wattenberg Media UG (haftungsbeschränkt)',
	alternateName: siteName,
	url: siteUrl,
	logo: {
		'@type': 'ImageObject',
		url: absoluteUrl('/icon-192.png'),
	},
	sameAs: [
		'https://www.youtube.com/channel/UCGu6U-UNczXKxShRiJj6kXQ',
		'https://www.linkedin.com/company/kwmediaug',
		'https://x.com/kwmediaUG',
	],
};
const websiteSchema = {
	'@type': 'WebSite',
	'@id': websiteId,
	url: siteUrl,
	name: siteName,
	publisher: { '@id': organizationId },
	inLanguage: schemaLanguageByLocale[locale],
};
const webPageSchema = {
	'@type': schemaType === 'ProfilePage' && profileAuthor ? 'ProfilePage' : 'WebPage',
	'@id': webPageId,
	url: canonicalHref,
	name: fullTitle,
	headline: title,
	description,
	isPartOf: { '@id': websiteId },
	breadcrumb: { '@id': breadcrumbId },
	primaryImageOfPage: socialImageHref ? { '@type': 'ImageObject', url: socialImageHref } : undefined,
	mainEntity:
		schemaType === 'BlogPosting'
			? { '@id': articleId }
			: schemaType === 'VideoObject' && video
				? { '@id': videoId }
				: schemaType === 'ProfilePage' && profileAuthor
					? { '@id': profilePersonId }
					: undefined,
	inLanguage: schemaLanguageByLocale[locale],
};
const profilePersonSchema =
	schemaType === 'ProfilePage' && profileAuthor
		? {
				'@type': 'Person',
				'@id': profilePersonId,
				name: profileAuthor.name,
				url: canonicalHref,
				jobTitle: profileAuthor.role,
				description: profileAuthor.description[locale],
				image: absoluteUrl(profileAuthor.image),
				email: profileAuthor.email,
				sameAs: profileAuthor.sameAs,
				affiliation: { '@id': organizationId },
				knowsAbout: profileAuthor.credentials,
			}
		: undefined;
const articleSchema =
	schemaType === 'BlogPosting'
		? {
				'@type': 'BlogPosting',
				'@id': articleId,
				mainEntityOfPage: { '@id': webPageId },
				headline: title,
				description,
				image: socialImageHref ? [socialImageHref] : undefined,
				datePublished: publishedTime,
				dateModified: modifiedTime ?? publishedTime,
				author: {
					'@type': 'Person',
					'@id': authorId,
					name: authorName ?? siteName,
					url: authorHref,
				},
				publisher: { '@id': organizationId },
				inLanguage: schemaLanguageByLocale[locale],
			}
		: undefined;
const videoSchema =
	schemaType === 'VideoObject' && video
		? {
				'@type': 'VideoObject',
				'@id': videoId,
				mainEntityOfPage: { '@id': webPageId },
				name: title,
				description,
				thumbnailUrl: [absoluteUrl(video.thumbnailUrl)],
				uploadDate: publishedTime,
				dateModified: modifiedTime ?? publishedTime,
				embedUrl: video.embedUrl,
				contentUrl: video.watchUrl,
				creator: {
					'@type': 'Person',
					'@id': authorId,
					name: authorName ?? siteName,
					url: authorHref,
				},
				publisher: { '@id': organizationId },
				potentialAction: {
					'@type': 'WatchAction',
					target: canonicalHref,
				},
				inLanguage: schemaLanguageByLocale[locale],
			}
		: undefined;
const breadcrumbSchema = {
	'@type': 'BreadcrumbList',
	'@id': breadcrumbId,
	itemListElement: breadcrumbItems,
};
const faqSchema = faqItems.length
	? {
			'@type': 'FAQPage',
			'@id': `${canonicalHref}#faq`,
			mainEntity: faqItems.map((item) => ({
				'@type': 'Question',
				name: item.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: item.answer.join(' '),
				},
			})),
		}
	: undefined;
const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@graph': [
		organizationSchema,
		websiteSchema,
		webPageSchema,
		profilePersonSchema,
		articleSchema,
		videoSchema,
		breadcrumbSchema,
		faqSchema,
	].filter(Boolean),
});
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32x32.png')} />
		<link rel="icon" type="image/png" sizes="192x192" href={withBase('/icon-192.png')} />
		<link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="color-scheme" content="light dark" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalHref} />
		{alternateLinksWithDefault.map((alternate) => <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />)}
		<link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssUrl} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta
			property="og:type"
			content={schemaType === 'BlogPosting' ? 'article' : schemaType === 'VideoObject' ? 'video.other' : 'website'}
		/>
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:locale" content={ogLocaleByLocale[locale]} />
		{ogLocaleAlternates.map((alternateLocale) => <meta property="og:locale:alternate" content={alternateLocale} />)}
		{socialImageHref && <meta property="og:image" content={socialImageHref} />}
		{socialImageHref && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
		<meta name="twitter:card" content={socialImageHref ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:site" content="@kwmediaUG" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		{socialImageHref && <meta name="twitter:image" content={socialImageHref} />}
		{socialImageHref && imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
		{schemaType === 'BlogPosting' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{schemaType === 'BlogPosting' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		{schemaType === 'BlogPosting' && authorName && <meta property="article:author" content={authorName} />}
		{priorityImagePreloadHref && <link rel="preload" as="image" href={priorityImagePreloadHref} fetchpriority="high" />}
		<script define:vars={{ themeStorageKey }}>
			(() => {
				const validThemes = new Set(['light', 'dark']);

				try {
					const storedTheme = localStorage.getItem(themeStorageKey);
					const theme = storedTheme && validThemes.has(storedTheme)
						? storedTheme
						: window.matchMedia('(prefers-color-scheme: dark)').matches
							? 'dark'
							: 'light';

					document.documentElement.dataset.theme = theme;
					document.documentElement.style.colorScheme = theme;
				} catch {
					document.documentElement.dataset.theme = 'light';
					document.documentElement.style.colorScheme = 'light';
				}
			})();
		</script>
		<script type="application/ld+json" set:html={jsonLd} />
		<title>{fullTitle}</title>
	</head>
	<body>
		<div class="site-shell">
			<SiteSidebar locale={locale} currentPath={currentPath} alternatePaths={effectiveAlternatePaths} />
			<div class="site-content">
				<main>
					<slot />
				</main>
				<SiteFooter locale={locale} />
			</div>
		</div>
		<CookieConsent locale={locale} measurementId={measurementId} />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-text: #241913;
		--color-ink: #241913;
		--color-muted: #6f6258;
		--color-surface: #ffffff;
		--color-surface-raised: #ffffff;
		--color-surface-alt: #fff6ed;
		--color-control-surface: #ffffff;
		--color-line: #ead8c8;
		--color-transparent: transparent;
		--color-accent: #ff6900;
		--color-accent-dark: #b84b00;
		--color-accent-soft: #fff1e4;
		--color-accent-on: #ffffff;
		--color-accent-dashed-line: color-mix(in srgb, var(--color-accent) 58%, var(--color-line));
		--color-accent-line: color-mix(in srgb, var(--color-accent) 55%, var(--color-line));
		--color-accent-focus: color-mix(in srgb, var(--color-accent) 30%, var(--color-transparent));
		--color-accent-focus-soft: color-mix(in srgb, var(--color-accent) 24%, var(--color-transparent));
		--color-accent-focus-subtle: color-mix(in srgb, var(--color-accent) 28%, var(--color-transparent));
		--color-deep: #1c1917;
		--color-deep-contrast: #ffffff;
		--color-deep-muted: rgba(255, 255, 255, 0.78);
		--color-deep-soft: rgba(255, 255, 255, 0.86);
		--color-deep-subtle: rgba(255, 255, 255, 0.06);
		--color-deep-border: rgba(255, 255, 255, 0.18);
		--color-deep-gradient-start: #241913;
		--color-deep-gradient-end: #3a302a;
		--color-header-background: rgba(255, 255, 255, 0.94);
		--color-media-background: #000000;
		--color-hero-panel: color-mix(in srgb, var(--color-deep) 74%, transparent);
		--color-hero-eyebrow: #ffb36b;
		--color-status-background: #f9f5f0;
		--color-status-positive-text: #225d2d;
		--color-status-positive-background: #edf8ef;
		--color-status-positive-border: #b7dec0;
		--color-status-negative-text: #8a2317;
		--color-status-negative-background: #fff0ed;
		--color-status-negative-border: #efb6aa;
		--color-positive-accent: #2e7b35;
		--color-negative-accent: #b83a24;
		--color-checkerboard-square: #f3eee9;
		--color-checkerboard-background: var(--color-surface-raised);
		--color-youtube-ink: #0f0f0f;
		--color-youtube-muted: #606060;
		--color-youtube-surface: #ffffff;
		--color-youtube-surface-alt: #f1f1f1;
		--color-youtube-phone: #f4f4f4;
		--color-youtube-phone-border: #dadada;
		--color-youtube-red: #ff0000;
		--color-youtube-play-icon: #ffffff;
		--color-youtube-overlay: rgba(0, 0, 0, 0.84);
		--color-youtube-placeholder-text: #4a4038;
		--color-youtube-placeholder-accent: rgba(255, 105, 0, 0.18);
		--color-youtube-placeholder-surface: rgba(255, 246, 237, 0.92);
		--color-youtube-placeholder-stripe: rgba(36, 25, 19, 0.08);
		--shadow-soft: 0 18px 60px rgba(36, 25, 19, 0.12);
		--shadow-raised: 0 18px 60px rgba(36, 25, 19, 0.18);
		--shadow-accent: 0 18px 50px rgba(255, 105, 0, 0.14);
		--shadow-hero: 0 24px 64px rgba(0, 0, 0, 0.28);
		--shadow-youtube-phone: 0 14px 40px rgba(36, 25, 19, 0.08);
		--font-body: Ubuntu, Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	:root[data-theme='dark'] {
		color-scheme: dark;
		--color-text: #f8efe8;
		--color-ink: #f8efe8;
		--color-muted: #c3b3a8;
		--color-surface: #14100d;
		--color-surface-raised: #1b1511;
		--color-surface-alt: #241b16;
		--color-control-surface: #211813;
		--color-line: #47362c;
		--color-transparent: transparent;
		--color-accent: #ff7a1a;
		--color-accent-dark: #ffb36b;
		--color-accent-soft: #3b2414;
		--color-accent-on: #140d08;
		--color-accent-dashed-line: color-mix(in srgb, var(--color-accent) 58%, var(--color-line));
		--color-accent-line: color-mix(in srgb, var(--color-accent) 55%, var(--color-line));
		--color-accent-focus: color-mix(in srgb, var(--color-accent) 30%, var(--color-transparent));
		--color-accent-focus-soft: color-mix(in srgb, var(--color-accent) 24%, var(--color-transparent));
		--color-accent-focus-subtle: color-mix(in srgb, var(--color-accent) 28%, var(--color-transparent));
		--color-deep: #080604;
		--color-deep-contrast: #ffffff;
		--color-deep-muted: rgba(255, 255, 255, 0.78);
		--color-deep-soft: rgba(255, 255, 255, 0.86);
		--color-deep-subtle: rgba(255, 255, 255, 0.08);
		--color-deep-border: rgba(255, 255, 255, 0.18);
		--color-deep-gradient-start: #080604;
		--color-deep-gradient-end: #241b16;
		--color-header-background: rgba(20, 16, 13, 0.94);
		--color-media-background: #000000;
		--color-hero-panel: color-mix(in srgb, var(--color-deep) 78%, transparent);
		--color-hero-eyebrow: #ffb36b;
		--color-status-background: #241d18;
		--color-status-positive-text: #93d99d;
		--color-status-positive-background: #12351a;
		--color-status-positive-border: #2e7b35;
		--color-status-negative-text: #ffb0a4;
		--color-status-negative-background: #421b16;
		--color-status-negative-border: #b83a24;
		--color-positive-accent: #93d99d;
		--color-negative-accent: #ff8d78;
		--color-checkerboard-square: #30251f;
		--color-checkerboard-background: #14100d;
		--color-youtube-ink: #f1f1f1;
		--color-youtube-muted: #aaaaaa;
		--color-youtube-surface: #0f0f0f;
		--color-youtube-surface-alt: #222222;
		--color-youtube-phone: #181818;
		--color-youtube-phone-border: #333333;
		--color-youtube-red: #ff0000;
		--color-youtube-play-icon: #ffffff;
		--color-youtube-overlay: rgba(0, 0, 0, 0.84);
		--color-youtube-placeholder-text: #f4cdb8;
		--color-youtube-placeholder-accent: rgba(255, 122, 26, 0.26);
		--color-youtube-placeholder-surface: rgba(36, 27, 22, 0.92);
		--color-youtube-placeholder-stripe: rgba(255, 255, 255, 0.08);
		--shadow-soft: 0 18px 60px rgba(0, 0, 0, 0.26);
		--shadow-raised: 0 18px 60px rgba(0, 0, 0, 0.34);
		--shadow-accent: 0 18px 50px rgba(255, 122, 26, 0.2);
		--shadow-hero: 0 24px 64px rgba(0, 0, 0, 0.42);
		--shadow-youtube-phone: 0 14px 40px rgba(0, 0, 0, 0.28);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		color: var(--color-ink);
		background: var(--color-surface);
		font-family: var(--font-body);
		line-height: 1.5;
	}

	a {
		color: inherit;
	}

	main {
		min-height: 60vh;
	}

	.youtube-consent-frame {
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: var(--color-deep);
		border-radius: 8px;
	}

	.youtube-consent-frame iframe {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.youtube-consent-placeholder {
		display: grid;
		width: 100%;
		height: 100%;
		min-height: 240px;
		place-content: center;
		justify-items: center;
		gap: 14px;
		padding: 24px;
		color: var(--color-deep-contrast);
		background: linear-gradient(135deg, var(--color-deep-gradient-start) 0%, var(--color-deep-gradient-end) 100%);
		text-align: center;
	}

	.youtube-consent-placeholder p {
		max-width: 48ch;
		margin: 0;
		color: var(--color-deep-soft);
		font-size: 0.98rem;
	}

	.youtube-consent-placeholder button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 16px;
		color: var(--color-accent-on);
		background: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 6px;
		font: inherit;
		font-weight: 850;
		cursor: pointer;
	}

	.site-shell {
		display: flex;
		min-height: 100vh;
		background: var(--color-surface);
	}

	.site-content {
		display: flex;
		flex: 1;
		flex-direction: column;
		min-width: 0;
	}

	.site-content main {
		flex: 1;
	}

	.container {
		width: min(1120px, calc(100% - 32px));
		margin-inline: auto;
	}

	.section {
		padding-block: clamp(48px, 8vw, 96px);
	}

	.eyebrow {
		margin: 0 0 12px;
		color: var(--color-accent-dark);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	@media (max-width: 900px) {
		.site-shell {
			display: block;
		}
	}
</style>
