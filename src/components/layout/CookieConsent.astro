---
import type { Locale } from '../../i18n';

interface Props {
	locale: Locale;
	measurementId?: string;
}

const { locale, measurementId } = Astro.props;
const copy = {
	de: {
		text: 'Wir nutzen Google Analytics und YouTube-Einbettungen nur nach Ihrer Zustimmung. YouTube kann separat erlaubt werden.',
		accept: 'Alle akzeptieren',
		youtube: 'Nur YouTube-Einbettungen',
		decline: 'Ablehnen',
	},
	en: {
		text: 'We use Google Analytics and YouTube embeds only after your consent. YouTube can be allowed separately.',
		accept: 'Accept all',
		youtube: 'YouTube embeds only',
		decline: 'Decline',
	},
}[locale];
const consentCookie = 'kwm_cookie_consent';
---

<div class="cookie-banner" data-cookie-banner hidden>
	<p>{copy.text}</p>
	<div class="cookie-actions">
		<button type="button" class="secondary" data-cookie-decline>
			{copy.decline}
		</button>
		<button type="button" class="secondary" data-cookie-youtube>
			{copy.youtube}
		</button>
		<button type="button" data-cookie-accept>
			{copy.accept}
		</button>
	</div>
</div>

<script define:vars={{ consentCookie, measurementId }}>
	const getConsent = () => {
		const match = document.cookie.match(new RegExp(`(?:^|; )${consentCookie}=([^;]*)`));
		return match ? decodeURIComponent(match[1]) : undefined;
	};

	const setConsent = (value) => {
		const secure = window.location.protocol === 'https:' ? '; Secure' : '';
		document.cookie = `${consentCookie}=${encodeURIComponent(value)}; Max-Age=31536000; Path=/; SameSite=Lax${secure}`;
	};

	const loadAnalytics = () => {
		if (!measurementId || window.kwmAnalyticsLoaded) {
			return;
		}

		window.kwmAnalyticsLoaded = true;
		window.dataLayer = window.dataLayer || [];
		window.gtag = function gtag() {
			window.dataLayer.push(arguments);
		};

		window.gtag('js', new Date());
		window.gtag('config', measurementId, { anonymize_ip: true });

		const script = document.createElement('script');
		script.async = true;
		script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId)}`;
		document.head.appendChild(script);
	};

	const loadYouTubeEmbeds = () => {
		document.querySelectorAll('[data-youtube-embed]').forEach((embed) => {
			if (embed.dataset.youtubeLoaded === 'true' || !embed.dataset.youtubeSrc) {
				return;
			}

			const iframe = document.createElement('iframe');
			iframe.src = embed.dataset.youtubeSrc;
			iframe.title = embed.dataset.youtubeTitle || 'YouTube video';
			iframe.loading = embed.dataset.youtubeLoading || 'lazy';
			iframe.allow = embed.dataset.youtubeAllow || 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';

			if (embed.dataset.youtubeReferrerpolicy) {
				iframe.setAttribute('referrerpolicy', embed.dataset.youtubeReferrerpolicy);
			}

			if (embed.hasAttribute('data-youtube-allowfullscreen')) {
				iframe.allowFullscreen = true;
			}

			embed.dataset.youtubeLoaded = 'true';
			embed.querySelector('.youtube-consent-placeholder')?.remove();
			embed.appendChild(iframe);
		});
	};

	const applyConsent = (value) => {
		if (value === 'accepted') {
			loadAnalytics();
			loadYouTubeEmbeds();
		} else if (value === 'youtube') {
			loadYouTubeEmbeds();
		}
	};

	const saveConsent = (value) => {
		setConsent(value);
		banner?.setAttribute('hidden', '');
		applyConsent(value);
	};

	const banner = document.querySelector('[data-cookie-banner]');
	const consent = getConsent();

	applyConsent(consent);

	if (!consent && banner) {
		banner.hidden = false;
	}

	document.querySelector('[data-cookie-accept]')?.addEventListener('click', () => {
		saveConsent('accepted');
	});

	document.querySelector('[data-cookie-youtube]')?.addEventListener('click', () => {
		saveConsent('youtube');
	});

	document.querySelector('[data-cookie-decline]')?.addEventListener('click', () => {
		saveConsent('declined');
	});

	document.addEventListener('click', (event) => {
		if (event.target instanceof Element && event.target.closest('[data-youtube-accept]')) {
			saveConsent('youtube');
		}
	});
</script>

<style>
	.cookie-banner {
		position: fixed;
		right: 18px;
		bottom: 18px;
		z-index: 50;
		display: grid;
		width: min(420px, calc(100vw - 36px));
		gap: 16px;
		padding: 18px;
		color: var(--color-ink);
		background: var(--color-surface-raised);
		border: 1px solid var(--color-line);
		border-radius: 8px;
		box-shadow: var(--shadow-raised);
	}

	.cookie-banner[hidden] {
		display: none;
	}

	p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.94rem;
	}

	.cookie-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 10px;
	}

	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 40px;
		padding: 0 14px;
		color: var(--color-accent-on);
		background: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 6px;
		font: inherit;
		font-weight: 850;
		cursor: pointer;
	}

	button.secondary {
		color: var(--color-ink);
		background: var(--color-surface-raised);
		border-color: var(--color-line);
	}

	@media (max-width: 560px) {
		.cookie-banner {
			right: 12px;
			bottom: 12px;
			width: calc(100vw - 24px);
		}

		.cookie-actions {
			justify-content: stretch;
		}

		button {
			flex: 1 1 140px;
		}
	}
</style>
