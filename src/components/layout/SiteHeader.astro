---
import { getNavigation } from '../../data/site';
import { localeLabels, routeFor, type Locale, useTranslations } from '../../i18n';
import { withBase } from '../../lib/url';

type AlternatePaths = Partial<Record<Locale, string>>;

interface Props {
	locale: Locale;
	alternatePaths?: AlternatePaths;
}

const { locale, alternatePaths = {} } = Astro.props;
const t = useTranslations(locale);
const navigation = getNavigation(locale);
const alternateLocale = locale === 'de' ? 'en' : 'de';
const alternatePath = alternatePaths[alternateLocale] ?? routeFor('home', alternateLocale);
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href={withBase(routeFor('home', locale))} aria-label={t('siteName')}>
			<img class="logo-light" src={withBase('/logo/logo-schwarz.svg')} alt="" width="230" height="91" />
			<img class="logo-dark" src={withBase('/logo/logo-weiß.svg')} alt="" width="230" height="91" />
		</a>
		<nav class="nav" aria-label="Main navigation">
			{
				navigation.map((item) => (
					<a href={withBase(item.href)}>{t(item.labelKey)}</a>
				))
			}
		</nav>
		<a class="language-link" href={withBase(alternatePath)}>
			{localeLabels[alternateLocale]}
		</a>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: var(--color-header-background);
		border-bottom: 1px solid var(--color-line);
		backdrop-filter: blur(10px);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 72px;
		gap: 24px;
	}

	.brand {
		display: block;
		color: var(--color-ink);
		font-weight: 800;
		text-decoration: none;
		white-space: nowrap;
	}

	.brand img {
		display: block;
		width: 184px;
		height: auto;
	}

	.logo-dark {
		display: none;
	}

	:global(:root[data-theme='dark']) .logo-light {
		display: none;
	}

	:global(:root[data-theme='dark']) .logo-dark {
		display: block;
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(12px, 3vw, 28px);
		color: var(--color-muted);
		font-size: 0.95rem;
		font-weight: 700;
	}

	.nav a,
	.language-link {
		text-decoration: none;
	}

	.nav a:hover,
	.language-link:hover {
		color: var(--color-accent-dark);
	}

	.language-link {
		color: var(--color-ink);
		font-size: 0.92rem;
		font-weight: 800;
	}

	@media (max-width: 760px) {
		.header-inner {
			flex-wrap: wrap;
			padding-block: 14px;
		}

		.nav {
			order: 3;
			width: 100%;
			justify-content: flex-start;
			overflow-x: auto;
			padding-bottom: 4px;
		}
	}
</style>
