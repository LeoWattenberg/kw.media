---
import type { HeroBlock } from '../data/pages';
import { withBase } from '../lib/url';

interface Props {
	block: HeroBlock;
}

const { block } = Astro.props;
---

<section class="hero">
	<div class="container hero-inner">
		<div class="hero-copy">
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h1>{block.title}</h1>
			<p>{block.text}</p>
			{
				block.actions && (
					<div class="actions">
						{block.actions.map((action) => (
							<a class:list={['button', action.variant === 'secondary' && 'secondary']} href={withBase(action.href)}>
								{action.label}
							</a>
						))}
					</div>
				)
			}
		</div>
		{
			block.image && (
				<div class="hero-media">
					<img src={block.image} alt={block.imageAlt ?? ''} loading="eager" />
				</div>
			)
		}
	</div>
</section>

<style>
	.hero {
		padding-block: clamp(56px, 9vw, 108px);
		background: #f4f7f8;
		border-bottom: 1px solid var(--color-line);
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
		gap: clamp(32px, 6vw, 76px);
		align-items: center;
	}

	.hero-copy {
		max-width: 720px;
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 7vw, 6.8rem);
		line-height: 0.94;
		letter-spacing: 0;
		text-wrap: balance;
	}

	p:not(.eyebrow) {
		max-width: 42rem;
		margin: 24px 0 0;
		color: var(--color-muted);
		font-size: clamp(1.05rem, 1.6vw, 1.25rem);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 32px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		min-height: 46px;
		padding: 0 18px;
		color: #fff;
		background: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 6px;
		font-weight: 800;
		text-decoration: none;
	}

	.button.secondary {
		color: var(--color-deep);
		background: #fff;
		border-color: var(--color-line);
	}

	.hero-media {
		position: relative;
		aspect-ratio: 4 / 5;
		min-height: 360px;
		overflow: hidden;
		border-radius: 8px;
		box-shadow: 0 22px 70px rgba(22, 51, 59, 0.14);
	}

	.hero-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 820px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: clamp(2.7rem, 16vw, 4.6rem);
		}

		.hero-media {
			min-height: 280px;
			aspect-ratio: 16 / 10;
		}
	}
</style>
