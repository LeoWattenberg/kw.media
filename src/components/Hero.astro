---
import type { HeroBlock } from '../data/pages';
import { localizeMediaUrl } from '../lib/media';
import { withBase } from '../lib/url';

interface Props {
	block: HeroBlock;
}

const { block } = Astro.props;
const heroImage = block.image ? withBase(localizeMediaUrl(block.image) ?? block.image) : undefined;
const heroStyle = heroImage ? `--hero-image: url(${encodeURI(heroImage)})` : undefined;
---

<section class:list={['hero', heroImage && 'has-image']} style={heroStyle}>
	<div class="container hero-inner">
		<div class="hero-copy">
			{block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
			<h1>{block.title}</h1>
			<p>{block.text}</p>
			{
				block.actions && (
					<div class="actions">
						{block.actions.map((action) => (
							<a class:list={['button', action.variant === 'secondary' && 'secondary']} href={withBase(action.href)}>
								{action.label}
							</a>
						))}
					</div>
				)
			}
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: flex;
		align-items: center;
		min-height: clamp(520px, 76vh, 780px);
		overflow: hidden;
		padding-block: clamp(64px, 11vw, 132px);
		background: var(--color-surface-alt);
		border-bottom: 1px solid var(--color-line);
	}

	.hero.has-image {
		color: #fff;
		background-image:
			linear-gradient(
				90deg,
				color-mix(in srgb, var(--color-deep) 88%, transparent),
				color-mix(in srgb, var(--color-deep) 58%, transparent) 48%,
				color-mix(in srgb, var(--color-deep) 16%, transparent)
			),
			var(--hero-image);
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
	}

	.hero-inner {
		position: relative;
		width: min(1120px, calc(100% - 32px));
	}

	.hero-copy {
		max-width: 760px;
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 7vw, 6.8rem);
		line-height: 0.94;
		letter-spacing: 0;
		text-wrap: balance;
	}

	.hero.has-image .eyebrow {
		color: #ffb36b;
	}

	p:not(.eyebrow) {
		max-width: 42rem;
		margin: 24px 0 0;
		color: var(--color-muted);
		font-size: clamp(1.05rem, 1.6vw, 1.25rem);
	}

	.hero.has-image p:not(.eyebrow) {
		color: rgba(255, 255, 255, 0.84);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 32px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		min-height: 46px;
		padding: 0 18px;
		color: #fff;
		background: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 6px;
		font-weight: 800;
		text-decoration: none;
	}

	.button.secondary {
		color: var(--color-deep);
		background: #fff;
		border-color: var(--color-line);
	}

	@media (max-width: 820px) {
		.hero {
			min-height: clamp(500px, 72vh, 680px);
		}

		h1 {
			font-size: clamp(2.7rem, 16vw, 4.6rem);
		}

	}
</style>
