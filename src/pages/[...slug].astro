---
import ArticlePage from '../components/ArticlePage.astro';
import PageRenderer from '../components/PageRenderer.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getSitePageAlternatePaths, getSitePageFaqItems, sitePages } from '../data/pages';
import { getAllPosts, getPostAlternatePaths } from '../lib/source-content';

export function getStaticPaths() {
	const pagePaths = sitePages
		.filter((page) => page.path !== '/')
		.map((page) => ({
			params: {
				slug: page.path.replace(/^\/|\/$/g, ''),
			},
			props: {
				kind: 'page',
				page,
			},
		}));

	const postPaths = getAllPosts().map((post) => ({
		params: {
			slug: post.path.replace(/^\/|\/$/g, ''),
		},
		props: {
			kind: 'post',
			post,
		},
	}));

	return [...pagePaths, ...postPaths];
}

const { kind, page, post } = Astro.props;
const heroBlock = kind === 'page' ? page.blocks.find((block) => block.type === 'hero') : undefined;
---

{
	kind === 'post' ? (
		<BaseLayout
			locale={post.locale}
			title={post.title}
			description={post.excerpt}
			preloadImage={post.video ? undefined : post.image}
			canonicalPath={post.path}
			alternatePaths={getPostAlternatePaths(post)}
			image={post.image}
			imageAlt={post.title}
			schemaType={post.video ? 'VideoObject' : 'BlogPosting'}
			publishedTime={post.date}
			modifiedTime={post.modified}
			authorName={post.authorName}
			video={post.video}
		>
			<ArticlePage post={post} />
		</BaseLayout>
	) : (
		<BaseLayout
			locale={page.locale}
			title={page.title}
			description={page.description}
			preloadImage={heroBlock?.image}
			canonicalPath={page.path}
			alternatePaths={getSitePageAlternatePaths(page)}
			image={heroBlock?.image}
			imageAlt={heroBlock?.imageAlt}
			faqItems={getSitePageFaqItems(page)}
		>
			<PageRenderer page={page} />
		</BaseLayout>
	)
}
