---
import ArticlePage from '../components/ArticlePage.astro';
import PageRenderer from '../components/PageRenderer.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { sitePages } from '../data/pages';
import { getAllPosts } from '../lib/source-content';

export function getStaticPaths() {
	const pagePaths = sitePages
		.filter((page) => page.path !== '/')
		.map((page) => ({
			params: {
				slug: page.path.replace(/^\/|\/$/g, ''),
			},
			props: {
				kind: 'page',
				page,
			},
		}));

	const postPaths = getAllPosts().map((post) => ({
		params: {
			slug: post.path.replace(/^\/|\/$/g, ''),
		},
		props: {
			kind: 'post',
			post,
		},
	}));

	return [...pagePaths, ...postPaths];
}

const { kind, page, post } = Astro.props;
---

{
	kind === 'post' ? (
		<BaseLayout locale={post.locale} title={post.title} description={post.excerpt}>
			<ArticlePage post={post} />
		</BaseLayout>
	) : (
		<BaseLayout locale={page.locale} title={page.title} description={page.description}>
			<PageRenderer page={page} />
		</BaseLayout>
	)
}
