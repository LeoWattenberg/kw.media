---
import PageRenderer from '../components/PageRenderer.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { findSitePage } from '../data/pages';

const page = findSitePage('/');

if (!page) {
	throw new Error('Missing homepage content');
}

const heroBlock = page.blocks.find((block) => block.type === 'hero');
---

<BaseLayout locale={page.locale} title={page.title} description={page.description} preloadImage={heroBlock?.image}>
	<PageRenderer page={page} />
</BaseLayout>
